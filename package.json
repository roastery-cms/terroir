{
	"name": "@roastery/terroir",
	"description": "Layered exception hierarchy and runtime schema validation for the Roastery CMS ecosystem",
	"version": "0.1.0",
	"type": "module",
	"author": {
		"name": "Alan Reis",
		"email": "alanreisanjo@gmail.com",
		"url": "https://github.com/Hoyasumii"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/roastery-cms/terroir"
	},
	"license": "MIT",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"keywords": [
		"framework",
		"hoyasumii",
		"roastery",
		"@roastery",
		"terroir",
		"@roastery/terroir",
		"roastery-terroir",
		"typescript",
		"exceptions",
		"exception-handling",
		"exception-hierarchy",
		"error-handling",
		"schema",
		"schema-validation",
		"runtime-validation",
		"typebox",
		"uuid",
		"uuid-v7",
		"clean-architecture",
		"ddd"
	],
	"typesVersions": {
		"*": {
			"*": [
				"./dist/*/index.d.ts"
			]
		}
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./*": {
			"types": "./dist/*/index.d.ts",
			"import": "./dist/*/index.js",
			"require": "./dist/*/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "biome check --fix && knip && tsup 'src/**/index.ts' --format cjs,esm --dts --tsconfig tsconfig.build.json --clean",
		"test:unit": "bun test --env-file=.env.testing",
		"test:coverage": "bun test --env-file=.env.testing --coverage",
		"setup": "bun run build && bun link",
		"prepare": "husky || true",
		"knip": "knip"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.1",
		"@commitlint/config-conventional": "^20.4.1",
		"husky": "^9.1.7",
		"knip": "^5.85.0"
	},
	"peerDependencies": {
		"typescript": "^5",
		"@types/bun": "latest",
		"tsup": "^8.5.1"
	},
	"dependencies": {
		"uuid": "^13.0.0",
		"@sinclair/typebox": ">= 0.34.0 < 1"
	}
}
